		<<link [[Next|Forest Shop Nowhere Passout]]>><<set $forest to 0>><<endevent>><<pass 15>><<run delete $gwylan.lureSong>><<run delete $gwylan.lureDistance>><<run delete $gwylan.lureWill>><</link>>
		<br>
	<<else>>
		<<link [[Next|Forest Gwylan Ritual Forced]]>><<set $forest to 0>><<endevent phaseless>><<run delete $gwylan.lureSong>><<run delete $gwylan.lureDistance>><</link>>
		<br>
	<</if>>
<<else>>
	<<link [[Walk towards the singing|Forest Gwylan Lure]]>><<set $phase to "willing">><<stress -1>><<trauma -1>><<arousal 500>><<pass 5>><</link>><<lstress>><<ltrauma>><<garousal>>
	<br>
	<<link [[Resist|Forest Gwylan Lure]]>><<set $phase to "resist">><<pass 5>><</link>><<gwylanWillpowerDifficulty>>
